# Copy this file to .env and fill in real values. Never commit .env.

# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

DJANGO_SETTINGS_MODULE=config.settings

# True for local development (plain http, relaxed cookie/HSTS rules).
# False (or omit) in production.
DEBUG=True

# Comma-separated. Include the host(s) you'll actually visit this on.
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional: only needed if you're deploying behind a custom domain over https.
# CSRF_TRUSTED_ORIGINS=https://your-domain.com

# --- Email (used by the CRM follow-up reminder command) ---
# Leave EMAIL_HOST blank to use the console backend (emails print to the terminal).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=tracker@example.com

# Who receives the daily CRM follow-up reminder email.
FOLLOWUP_REMINDER_TO=you@example.com

# Who receives the daily "still open today" task/habit reminder email
# (run via: python manage.py daily_reminder, scheduled with cron at ~6pm).
DAILY_REMINDER_TO=you@example.com
ADMIN_EMAIL=you@example.com
SERVER_EMAIL=tracker@example.com
CONTACT_EMAIL=you@example.com

# --- Desktop app (packaged .exe, see desktop.py / build_exe.bat) ---
# Used by: python manage.py create_default_user
# Creates this login automatically on first run, if no user exists yet.
# DEFAULT_USER_EMAIL=admin@example.com
# DEFAULT_USER_PASSWORD=admin123

# --- AI generation (assets app: turn uploaded content into blog/email/funnel
# copy, and distill a brand voice profile) ---
# Works with Anthropic (Claude), OpenAI (ChatGPT), or Google (Gemini) — set
# AI_PROVIDER to whichever one your key is for. Without a key, generation
# features show a clear error instead of failing silently.
#
# End users (including the packaged .exe) set these from inside the app —
# Settings in the sidebar — not here. These env vars are a dev-only
# fallback, used if nothing is saved in Settings yet.
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=
